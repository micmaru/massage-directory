rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin identity — single hardcoded UID for now (Option 1)
    // Upgrade to admins collection (Option 2) before scaling
    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'BGI0KYCKnYVM85GdlH1CG2KHP0p2';
    }

    // Supplier owns their own record — checked via uid field on document
    function isOwnSupplier(supplierId) {
      return request.auth != null
          && get(/databases/$(database)/documents/suppliers/$(supplierId)).data.uid
             == request.auth.uid;
    }

    // Suppliers — public read (customer display), own update, admin full access
    match /suppliers/{supplierId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if isOwnSupplier(supplierId) || isAdmin();
      allow delete: if isAdmin();

      match /changeLogs/{logId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }
    }

    // Wildcard changeLogs — covers any nested path
    match /{path=**}/changeLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Pending registrations — own record or admin only
    match /pending_registrations/{cellNumber} {
      allow read: if request.auth != null
                  && request.auth.token.phone_number == cellNumber
                  || isAdmin();
      allow write: if request.auth != null
                   && request.auth.token.phone_number == cellNumber
                   || isAdmin();
    }

    // Audit log — append-only (create allowed, update/delete never)
    match /auditLog/{document=**} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    // Settings/config — public read (client needs pricing), admin write only
    match /settings/config {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Subscriptions — admin read/write only
    // Cloud Functions use Admin SDK (bypass rules) — isAdmin() adds manual override
    match /subscriptions/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Payments — server-side only, deny all client access
    match /payments/{document=**} {
      allow read, write: if false;
    }

    // Terms documents — public read, admin write
    match /termsDocuments/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Enquiries — feature permanently removed, deny everything
    match /enquiries/{document=**} {
      allow read, write: if false;
    }

    // Areas shadow collection — public read, admin write
    match /areas/{areaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Location reference data — public read, admin write
    match /locations_provinces/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locations_towns/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locations_areas/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locations_suburbs/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Offerings / associations — public read, admin write
    match /offerings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Catch-all — deny everything not explicitly matched above
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
