rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Suppliers: public read, authenticated user can create their own document
    match /suppliers/{supplierId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == supplierId;
    }

    // Enquiries: public read and write (customer contact form submissions)
    match /enquiries/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // Payments: no public access
    match /payments/{document=**} {
      allow read, write: if false;
    }

    // Subscriptions: no public access
    match /subscriptions/{document=**} {
      allow read, write: if false;
    }

    // Settings: public read allowed (pricing config), no public write
    // Exception: authenticated users may increment the supplier counter during registration
    match /settings/supplierCounter {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
