{
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Read(functions/.env)",
      "Write(functions/.env)",
      "Edit(functions/.env)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous-commands.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/warn-large-files.sh"
          }
        ]
      }
    ]
  }
}
